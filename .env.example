# TENKA — environment configuration
#
# Copy this file to `.env` and fill in the values you need.
# Or just run: python scripts/setup.py — and the wizard will write
# this file for you, prompting only for what's required.
#
# Lines starting with `#` are comments. `KEY=VALUE`, no quotes around values.

# ─── LLM providers (at least ONE cloud key strongly recommended) ─────
# TENKA routes most tasks through Gemini Flash. Without it, you fall
# back to Groq/Cerebras free tiers, which are rate-limited.

# Gemini — primary. Most tasks (intent, planning, synthesis, vision) route here.
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — fallback. Free tier ~1K requests/day on llama-3.3-70b.
# Get a key: https://console.groq.com/
GROQ_API_KEY=

# Cerebras — fallback. Free tier, fast inference on small models.
# Get a key: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# Tavily — web search. Free tier ~1K searches/month.
# Get a key: https://app.tavily.com/
TAVILY_API_KEY=

# Jina — reranker for memory retrieval. Optional — falls back to local rerank.
# Get a key: https://jina.ai/api-dashboard/
JINA_API_KEY=

# Hugging Face — only needed for gated models. Most TENKA defaults are open.
# Get a token: https://huggingface.co/settings/tokens
HF_TOKEN=

# Ollama — fully local fallback. No API key, but needs a running daemon.
# Run: ollama serve   then:   ollama pull llama3
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3

# ─── Region / timezone ───────────────────────────────────────────────
# Two-letter country code (e.g. US, IN, GB, DE, JP) — used by services
# that need a market hint (Spotify, YouTube, etc.). The setup wizard
# auto-detects from your system locale; override here if it guessed wrong.
USER_REGION=

# IANA timezone name (e.g. America/New_York, Asia/Kolkata, Europe/Berlin).
# The setup wizard auto-detects; override here if it guessed wrong.
USER_TIMEZONE=

# ─── Logging ─────────────────────────────────────────────────────────
# DEBUG_LOG=true

# ─── Optional feature flags (defaults shown — uncomment to override) ─
# Wake-word listening on startup
# WAKE_WORD_ENABLED=true

# Camera (face recognition + visual context)
# CAMERA_ENABLED=true

# Speaker verification (per-user voice gating)
# SPEAKER_VERIFY_ENABLED=true

# Knowledge graph ingestion (fact extraction from conversation)
# KG_INGEST_ENABLED=true

# Proactive suggestions
# PROACTIVE_ENABLED=true

# ─── Advanced tunables (rarely needed) ───────────────────────────────
# STT_BACKEND=faster_whisper
# FASTER_WHISPER_MODEL=small.en
# TTS_VOICE=af_bella
# TTS_SPEED=1.0
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# CEREBRAS_MODEL=gpt-oss-120b
